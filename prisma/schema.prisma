generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  passwordHash String
  role         UserRole @default(CLIENT)
  // Legacy (kept temporarily for safe migration/backfill).
  clientName   String   @default("unassigned")
  clientId     String?
  client       Client?  @relation(fields: [clientId], references: [id], onDelete: SetNull)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Client {
  id        String    @id @default(cuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  users     User[]
  projects  Project[]
}

model Project {
  id                     String         @id @default(cuid())
  projectNo              String         @unique
  // Legacy (kept temporarily for safe migration/backfill).
  clientName             String
  clientId               String?
  client                 Client?        @relation(fields: [clientId], references: [id], onDelete: SetNull)
  equipmentType          String
  orderDate              DateTime
  deliveryDate           DateTime
  status                 ProjectStatus  @default(PLANNING)
  createdAt              DateTime       @default(now())
  updatedAt              DateTime       @updatedAt
  isDeleted              Boolean        @default(false)
  dispatchedAt           DateTime?
  completionDays         Int?
  deletedAt              DateTime?
  drawingReceivedDate    DateTime?
  expectedCompletionDate DateTime?
  productionDurationDays Int            @default(28)
  excludeSundays         Boolean        @default(false)
  activityLogs           ActivityLog[]
  stages                 ProjectStage[]
  stageProgressLogs      StageProgressLog[]

  @@index([status])
  @@index([clientId])
  @@index([isDeleted])
}

model ProductionStage {
  id            String         @id @default(cuid())
  name          String         @unique
  weight        Float
  sortOrder     Int            @default(0)
  projectStages ProjectStage[]

  @@index([sortOrder])
}

model ProjectStage {
  id           String          @id @default(cuid())
  projectId    String
  stageId      String
  status       StageStatus     @default(NOT_STARTED)
  progress     Float           @default(0)
  plannedDate  DateTime?
  actualDate   DateTime?
  delayReason  String?
  isDelayed    Boolean         @default(false)
  stageDetails Json?
  createdAt    DateTime        @default(now())
  updatedAt    DateTime        @updatedAt
  project      Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  stage        ProductionStage @relation(fields: [stageId], references: [id])

  @@unique([projectId, stageId])
  @@index([projectId])
  @@index([status])
}

model StageProgressLog {
  id             String   @id @default(cuid())
  projectId      String
  projectStageId String
  stageName      String
  field          String
  previousValue  String?
  newValue       String?
  updatedBy      String
  createdAt      DateTime @default(now())
  project        Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([projectStageId])
  @@index([createdAt])
}

model ActivityLog {
  id        String   @id @default(cuid())
  projectId String
  action    String
  entity    String
  entityId  String?
  details   Json?
  createdAt DateTime @default(now())
  project   Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([projectId])
  @@index([action])
}

enum ProjectStatus {
  PLANNING
  IN_PRODUCTION
  COMPLETED
  DELAYED
  DISPATCHED
}

enum StageStatus {
  NOT_STARTED
  IN_PROGRESS
  COMPLETED
}

enum UserRole {
  ADMIN
  CLIENT
}
